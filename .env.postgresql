# 服务器配置
PORT=3001
NODE_ENV=production

# 数据库配置 (PostgreSQL - 生产环境)
DATABASE_URL="postgresql://postgres:password@localhost:5432/aafa_db?schema=public"

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 前端地址（用于 CORS）
FRONTEND_URL=http://localhost:3000

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
