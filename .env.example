# ============================================
# AAFA 后端环境配置示例
# 复制此文件为 .env 并根据环境修改
# ============================================

# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置 (PostgreSQL)
# 开发环境：使用本地 PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aafa_db?schema=public"

# 生产环境：使用 Railway/Render 提供的数据库 URL
# DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public&sslmode=require"

# JWT 配置
# ⚠️ 重要：生产环境必须更换为 32+ 位的随机字符串！
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# 前端地址（用于 CORS）
# 开发环境
FRONTEND_URL=http://localhost:3000

# 生产环境
# FRONTEND_URL=https://your-frontend-domain.com

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ============================================
# 可选：第三方服务配置
# ============================================

# 邮件服务 (用于发送通知)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password

# 云存储 (用于文件上传)
# AWS_S3_BUCKET=your-bucket
# AWS_S3_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
